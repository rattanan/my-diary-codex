generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model DiaryEntry {
  id        String   @id @default(uuid())
  title     String
  content   String
  mood      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("diary_entries")
}
